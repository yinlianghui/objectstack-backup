range(0, 1)  # B2:E4"].join("\n"),summary:"Grow a range by one column"},{code:["range = sheet.get_range('B2:D4')","smaller = range.get_resized_range(-1, -1)  # B2:C3"].join("\n"),summary:"Shrink a range by one row and one column"}]}},notes:["Compatibility helper modeled after Office.js Range.getResizedRange(deltaRows, deltaColumns).","If you have a matrix and just want to write it starting at a single cell, prefer a spill write: sheet.getRange('B2').values = matrix."]},{kind:"api",name:"range.getResizeRange",summary:"Return a range resized to an explicit row/column count, anchored at the current top-left cell.",languages:{javascript:{examples:[{code:["const range = sheet.getRange('B2:D4');","const block = range.getResizeRange(5, 2); // B2:C6"].join("\n"),summary:"Resize to a specific shape"}]},python:{functionName:"range.get_resize_range",examples:[{code:["range = sheet.get_range('B2:D4')","block = range.get_resize_range(5, 2)  # B2:C6"].join("\n"),summary:"Resize to a specific shape"}]}},notes:["Granola convenience helper (absolute size).","Equivalent to range.getOffsetRange(0, 0, rowCount, columnCount)."]},{kind:"api",name:"range.offset",summary:"Alias for range.getOffsetRange(...).",languages:{javascript:{},python:{functionName:"range.offset"}},notes:["Use range.getOffsetRange for the full signature and examples."]},{kind:"api",name:"range.resize",summary:"Alias for range.getResizeRange(rowCount, columnCount).",languages:{javascript:{},python:{functionName:"range.resize"}},notes:["This is an absolute resize helper.","Use range.getResizedRange(deltaRows, deltaColumns) when you want Office.js-style delta resize."]},{kind:"api",name:"range.write",summary:"Write a 2D matrix anchored at this range's top-left (auto-sizes the target).",languages:{javascript:{examples:[{code:["const anchor = sheet.getRange('B2');","const block = anchor.write([['A','B'],[1,2],[3,4]]);","// block is the resized range (B2:C4)","block.format.autofitColumns();"].join("\n"),summary:"Write a matrix without computing the end cell"}]},python:{functionName:"range.write",examples:[{code:["anchor = sheet.get_range('B2')","block = anchor.write([['A', 'B'], [1, 2], [3, 4]])","# block is the resized range (B2:C4)","block.format.autofit_columns()"].join("\n"),summary:"Write a matrix without computing the end cell"}]}},notes:["Prefer this over hand-building A1 end-cells like 'B2:F17'.","You can pass overwrite: 'error' to prevent overwriting existing content.","1D input is treated as a single row (wrap as [[...]] for 2D)."]},{kind:"api",name:"range.values",summary:"Read or write cell values using a 2D array.",languages:{javascript:{examples:[{code:["const range = sheet.getRange('A1:C2');","range.values = [['Date', 'Dog', 'HR'], ['2025-01-02', 'Nova', 58]];"].join("\n"),summary:"Write a values grid"}]},python:{functionName:"range.values",examples:[{code:["range = sheet.get_range('A1:C2')","range.values = [['Date', 'Dog', 'HR'], ['2025-01-02', 'Nova', 58]]"].join("\n"),summary:"Write a values grid"}]}},notes:["Values are string | number | boolean | Date | null.","Single-cell ranges spill to fit larger matrices.","Single-row ranges also accept 1D arrays (treated as a row).","Single-column ranges also accept 1D arrays (treated as a column).","Granola auto-fixes common transposed vectors for 1-row/1-col ranges (Nx1 vs 1xN).","Use range.values = null to clear contents."]},{kind:"api",name:"range.formulas",summary:"Read or write formulas using a 2D string array.",languages:{javascript:{examples:[{code:["sheet.getRange('A1:A3').values = [[5], [2], [3]];","sheet.getRange('B1').formulas = [['=SUM(A:A)']];","workbook.recalculate();","const total = sheet.getRange('B1').values[0]?.[0];"].join("\n"),summary:"Write a formula and recalculate"}]},python:{functionName:"range.formulas",examples:[{code:["sheet.get_range('A1:A3').values = [[5], [2], [3]]","sheet.get_range('B1').formulas = [['=SUM(A:A)']]","workbook.recalculate()","total = sheet.get_range('B1').values[0][0]"].join("\n"),summary:"Write a formula and recalculate"}]}},notes:["Formula strings may include or omit the leading '='.","Single-cell ranges spill to fit larger matrices.","Single-row and single-column ranges also accept 1D arrays.","Granola auto-fixes common transposed vectors for 1-row/1-col ranges (Nx1 vs 1xN)."]},{kind:"api",name:"range.clear",summary:"Clear contents and/or formatting for a range.",languages:{javascript:{examples:[{code:"sheet.getRange('A1:C10').clear();",summary:"Clear contents"},{code:"sheet.getRange('A1:C10').clear({ applyTo: 'all' });",summary:"Clear contents and formats"}]},python:{functionName:"range.clear",examples:[{code:"sheet.get_range('A1:C10').clear()",summary:"Clear contents"},{code:"sheet.get_range('A1:C10').clear({'apply_to': 'all'})",summary:"Clear contents and formats"}]}},notes:["applyTo accepts 'contents', 'formats', or 'all'.","Clearing formats does not change row/column sizing.","Clearing ranges does not delete charts, shapes, or images."]},{kind:"api",name:"ranges",summary:"Range addressing and cell reads/writes.",languages:{javascript:{},python:{functionName:"worksheet.get_range"}},notes:["Create ranges with worksheet.getRange('A1:C10').","Write with range.values or range.formulas.","Use range.rowCount/range.columnCount (or range.getRowCount()/getColumnCount()) to inspect range dimensions.","Use range.formulasR1C1 when it's easier to generate relative formulas (e.g. RC[-1]) and let the API translate them.",`range.values treats strings starting with '=' as formulas; use "'=..." to force literal text.`,"range.values and range.formulas require a rectangular matrix matching the range size; single-cell ranges spill to fit larger matrices.","Clear with range.clear() or range.values = null."]},{kind:"api",name:"range.fillDown",summary:"Copy the first row down, shifting formulas.",languages:{javascript:{examples:[{code:["const r = sheet.getRange('B2:B10');","r.getCell(0, 0).formulasR1C1 = [['=RC[-1]*2']];","r.fillDown();"].join("\n"),summary:"Fill down like Excel drag-fill"}]},python:{functionName:"range.fill_down",examples:[{code:["r = sheet.get_range('B2:B10')","r.get_cell(0, 0).formulas_r1_c1 = [['=RC[-1]*2']]","r.fill_down()"].join("\n"),summary:"Fill down like Excel drag-fill"}]}},notes:["Copies formulas/values from the first row to the rest of the range.","Relative references are shifted per row."]},{kind:"api",name:"range.fillRight",summary:"Copy the first column right, shifting formulas.",languages:{javascript:{examples:[{code:["const r = sheet.getRange('B2:F2');","r.getCell(0, 0).formulasR1C1 = [['=RC[-1]*2']];","r.fillRight();"].join("\n"),summary:"Fill right like Excel drag-fill"}]},python:{functionName:"range.fill_right",examples:[{code:["r = sheet.get_range('B2:F2')","r.get_cell(0, 0).formulas_r1_c1 = [['=RC[-1]*2']]","r.fill_right()"].join("\n"),summary:"Fill right like Excel drag-fill"}]}},notes:["Copies formulas/values from the first column to the rest of the range.","Relative references are shifted per column."]},{kind:"api",name:"range.fillFrom",summary:"Fill a larger one-axis range from a source block, repeating values and shifting formulas.",languages:{javascript:{examples:[{code:["const seed = sheet.getRange('B2:C3');","const target = sheet.getRange('B2:C8');","target.fillFrom(seed);"].join("\n"),summary:"Extend a block downward from a source selection"}]},python:{functionName:"range.fill_from",examples:[{code:["seed = sheet.get_range('B2:C3')","target = sheet.get_range('B2:C8')","target.fill_from(seed)"].join("\n"),summary:"Extend a block downward from a source selection"}]}},notes:["Destination must extend source in exactly one direction while sharing the other axis.","Repeated tails are allowed even when the destination size is not an even multiple of the source size.","Copies literal values exactly and shifts relative formula references; it does not infer numeric/date series.","Cell formatting and data validation are not propagated."]},{kind:"api",name:"range.copyFrom",summary:"Copy values/formulas from another range (supports 1x1 broadcast).",languages:{javascript:{examples:[{code:["// Excel-like drag-fill across a whole block (no manual 2D matrix)","const grid = sheet.getRange('B3:AF17');","const seed = sheet.getRange('B3');","seed.formulasR1C1 = [['=RC[-1]*2']];","grid.copyFrom(seed, 'formulas');"].join("\n"),summary:"Fill a block of formulas using copyFrom"}]},python:{functionName:"range.copy_from",examples:[{code:["# Excel-like drag-fill across a whole block (no manual 2D matrix)","grid = sheet.get_range('B3:AF17')","seed = sheet.get_range('B3')","seed.formulas_r1_c1 = [['=RC[-1]*2']]","grid.copy_from(seed, 'formulas')"].join("\n"),summary:"Fill a block of formulas using copyFrom"}]}},notes:["When source is 1x1, copyFrom broadcasts to the destination shape.","When copying formulas, relative references shift across the destination cells."]}];var abr=["tables","table","worksheet.tables","tables.add"];var sbr=[{kind:"api",name:"tables",tags:abr.concat(["tables add","table add"]),summary:"Excel table objects on a worksheet.",notes:["Use worksheet.tables.add('A1:D10', true) (or worksheet.getRange('A1:D10')) to create a table.","Use worksheet.tables.getItem(name) to access an existing table.","Use worksheet.tables.getItemAt(index) to access tables by position.","Use worksheet.tables.getItemOrNullObject(name) when the table may not exist; check table.isNullObject before using it.","Use table.delete() to remove a single table, or worksheet.tables.deleteAll() to remove all tables."],languages:{javascript:{},python:{functionName:"worksheet.tables.add"}}},{kind:"api",name:"data-tables",tags:abr.concat(["data tables add","data_tables.add"]),summary:"What-if data tables for formulas.",notes:["Use worksheet.dataTables.add('C2:E5', { rowInput, columnInput }) with the formula in the top-left cell of the range.","Data tables require at least a rowInput or columnInput."],languages:{javascript:{},python:{functionName:"worksheet.data_tables.add"}}}];var lbr=["sheets","worksheets"];var cbr=[{kind:"api",name:"worksheets",tags:lbr,summary:"Worksheet collection and selection.",languages:{javascript:{notes:["Use workbook.worksheets.add(name) to create sheets.","Use workbook.worksheets.getItem(name) to select by name.","Use workbook.worksheets.getOrAdd(name, { renameFirstIfOnlyNewSpreadsheet: true }) to create-or-reuse.","Use workbook.worksheets.getItemAt(index) to select by index.","Use workbook.worksheets.getActiveWorksheet() for the active sheet."]},python:{notes:["Use workbook.worksheets.add(name) to create sheets.","Use workbook.worksheets.get_item(name) to select by name.","Use workbook.worksheets.get_or_add(name, { renameFirstIfOnlyNewSpreadsheet: True }) to create-or-reuse.","Use workbook.worksheets.get_item_at(index) to select by index.","Use workbook.worksheets.get_active_worksheet() for the active sheet."]}}},{kind:"api",name:"worksheets get or add",tags:lbr,summary:"Get an existing worksheet by name or create it if missing.",languages:{javascript:{examples:[{code:["const sheet = workbook.worksheets.getOrAdd('Dashboard', {","  renameFirstIfOnlyNewSpreadsheet: true,","});"].join("\n"),summary:"Create-or-reuse a worksheet"}]},python:{functionName:"workbook.worksheets.get_or_add(name, options)",examples:[{code:["sheet = workbook.worksheets.get_or_add(","  'Dashboard',","  {'renameFirstIfOnlyNewSpreadsheet': True},",")"].join("\n"),summary:"Create-or-reuse a worksheet"}]}}},{kind:"api",name:"worksheet.freezePanes",tags:["freeze panes","freeze_panes","freeze_rows","freeze_columns","unfreeze"],summary:"Freeze or unfreeze worksheet panes.",languages:{javascript:{examples:[{code:["const sheet = workbook.worksheets.getItem('Data');","sheet.freezePanes.freezeRows(1);","sheet.freezePanes.freezeColumns(2);"].join("\n"),summary:"Freeze header row and first two columns"}]},python:{functionName:"worksheet.freeze_panes",examples:[{code:["sheet = workbook.worksheets.get_item('Data')","sheet.freeze_panes.freeze_rows(1)","sheet.freeze_panes.freeze_columns(2)"].join("\n"),summary:"Freeze header row and first two columns"},{code:"sheet.freeze_panes.unfreeze()",summary:"Unfreeze panes"}]}}},{kind:"api",name:"worksheet.showGridLines",tags:["show_grid_lines","showGridLines","grid lines","gridlines","worksheet.show_grid_lines"],summary:"Worksheet gridline visibility surface.",languages:{python:{functionName:"worksheet.show_grid_lines"}}},{kind:"api",name:"worksheet.getUsedRange",summary:"Return the used range for a worksheet.",languages:{javascript:{notes:["Used range is the smallest rectangle covering cells that have been created (values, formulas, or formatting).","Use sheet.getUsedRange(true) to approximate values-only used bounds."],examples:[{code:["const sheet = workbook.worksheets.getItem('Sheet1');","const used = sheet.getUsedRange();","used.clear({ applyTo: 'all' });"].join("\n"),summary:"Clear the used range"}]},python:{functionName:"worksheet.get_used_range",notes:["Used range is the smallest rectangle covering cells that have been created (values, formulas, or formatting).","Use worksheet.get_used_range(true) to approximate values-only used bounds."],examples:[{code:["used = sheet.get_used_range()","used.clear({'apply_to': 'all'})"].join("\n"),summary:"Clear the used range"}]}}},{kind:"api",name:"worksheet.reset",summary:"Clear the sheet and delete common objects (tables, charts, drawings, sparklines).",notes:["Defaults clear the used range (applyTo='all') and delete tables/charts/drawings/sparklines.","Pass options to keep objects or to clear formats/contents selectively."],languages:{javascript:{examples:[{code:["const sheet = workbook.worksheets.getItem('Sheet1');","sheet.reset();"].join("\n"),summary:"Reset a worksheet for a clean rebuild"}]},python:{functionName:"worksheet.reset",examples:[{code:"sheet.reset()",summary:"Reset a worksheet for a clean rebuild"}]}}}];var NNe=["conditional-formatting","conditional formatting","conditional format"];var ubr=[{kind:"api",name:"conditional-formatting",tags:NNe,summary:"Conditional formatting rules for ranges.",languages:{javascript:{notes:["Use range.conditionalFormats.add(type, config) to add rules.","Use range.conditionalFormats.clear() (or deleteAll()) to remove rules.","Use range.conditionalFormats.add('Custom', { formula, format }) for expression rules.","Convenience aliases: range.conditionalFormats.addExpression(...) and addCustom(...).","Compat alias: use type='CellValue' for cellIs rules.","Use range.conditionalFormats.addCellIs({ operator, formula, format }) for cellIs rules."]},python:{functionName:"range.conditional_formats.add",notes:["Use range.conditional_formats.add(type, config) to add rules.","Use range.conditional_formats.clear() (or delete_all()) to remove rules.","Use range.conditional_formats.add('Custom', {'formula': ..., 'format': ...}) for expression rules.","Convenience aliases: range.conditional_formats.add_expression(...) and add_custom(...).","Compat alias: use type='CellValue' for cellIs rules.","Use range.conditional_formats.add_cell_is({'operator': ..., 'formula': ..., 'format': ...}) for cellIs rules."]}},notes:["Supported authored rule families include: cellIs, expression (Custom), containsText/notContainsText, beginsWith/endsWith, containsBlanks/notContainsBlanks, containsErrors/notContainsErrors, duplicateValues/uniqueValues, timePeriod, top10, aboveAverage, colorScale, dataBar, and iconSet.","colorScale accepts { colors, thresholds } or criteria objects/arrays.","iconSet accepts built-in Excel icon names such as 3Arrows, 3TrafficLights1, 4Rating, and 5Boxes, and it auto-generates 3/4/5 thresholds when omitted."]},{kind:"api",name:"range.conditionalFormats",tags:NNe,summary:"Conditional formatting rules scoped to a range.",languages:{javascript:{notes:["Use range.conditionalFormats.add(type, config) to add rules.","Use range.conditionalFormats.clear() (or deleteAll()) to remove rules.","Use range.conditionalFormats.addCellIs({ operator, formula, format }) for cellIs rules.","Use range.conditionalFormats.addExpression(...) and addCustom(...) as expression-rule convenience aliases."],examples:[{code:["const range = sheet.getRange('B2:B6');","range.conditionalFormats.add('colorScale', {","  colors: ['#FCA5A5', '#DC2626'],","});"].join("\n"),summary:"Add a color scale rule"},{code:["const range = sheet.getRange('B2:B6');","range.conditionalFormats.add('colorScale', {","  criteria: [","    { type: 'lowestValue', color: '#DC2626' },","    { type: 'percentile', value: 50, color: '#FBBF24' },","    { type: 'highestValue', color: '#16A34A' },","  ],","});"].join("\n"),summary:"Add a 3-stop color scale (min/mid/max)"},{code:["const range = sheet.getRange('B2:B6');","range.conditionalFormats.add('Custom', {","  formula: '=B2>10',","  format: { fill: '#FDE68A', font: { bold: true } },","});"].join("\n"),summary:"Add a custom formula rule"},{code:["const range = sheet.getRange('B2:B6');","range.conditionalFormats.addCellIs({","  operator: 'lessThan',","  formula: 0,","  format: { fill: '#F8CBAD' },","});"].join("\n"),summary:"Add a cell value rule"},{code:["const range = sheet.getRange('C2:C10');","range.conditionalFormats.add('dataBar', {","  color: 'accent5',","  gradient: true,","});"].join("\n"),summary:"Add data bars (color bars) for magnitude"},{code:["const range = sheet.getRange('D2:D10');","range.conditionalFormats.add('iconSet', {","  iconSet: '3Arrows',","  showValue: false,","  reverse: false,","  percent: true,","});"].join("\n"),summary:"Add an icon set for quick up/flat/down signals"},{code:["const range = sheet.getRange('E2:E8');","range.conditionalFormats.add('containsText', {","  text: 'late',","  format: { fill: '#FDE68A', font: { color: '#92400E', bold: true } },","});"].join("\n"),summary:"Highlight text cells that contain a substring"},{code:["const range = sheet.getRange('F2:F12');","range.conditionalFormats.add('timePeriod', {","  timePeriod: 'last7Days',","  format: { fill: '#DBEAFE', font: { color: '#1D4ED8' } 