n:"Is the value you want to test. Value can refer to a cell, a formula, or a name that refers to a cell, formula, or value",type:"value|range",optional:false}]},{name:"ISTEXT",category:"information",id:101,description:"Checks whether a value is text, and returns TRUE or FALSE",example:"=ISTEXT(A1:A5)",parameters:[{name:"value",description:"Is the value you want to test. Value can refer to a cell, a formula, or a name that refers to a cell, formula, or value",type:"value|range",optional:false}]},{name:"ISNUMBER",category:"information",id:102,description:"Checks whether a value is a number, and returns TRUE or FALSE",example:"=ISNUMBER(A1:A5)",parameters:[{name:"value",description:"Is the value you want to test. Value can refer to a cell, a formula, or a name that refers to a cell, formula, or value",type:"value|range",optional:false}]},{name:"ISBLANK",category:"information",id:103,description:"Checks whether a reference is to an empty cell, and returns TRUE or FALSE",example:"=ISBLANK(A1:A5)",parameters:[{name:"value",description:"Is the cell or a name that refers to the cell you want to test",type:"value|range",optional:false}]},{name:"N",category:"information",id:105,description:"Converts non-number value to a number, dates to serial numbers, TRUE to 1, anything else to 0 (zero)",example:"=N(A1:A5)",parameters:[{name:"value",description:"Is the value you want converted",type:"value|range",optional:false}]},{name:"ISNONTEXT",category:"information",id:122,description:"Checks whether a value is not text (blank cells are not text), and returns TRUE or FALSE",example:"=ISNONTEXT(A1:A5)",parameters:[{name:"value",description:"Is the value you want tested: a cell; a formula; or a name referring to a cell, formula, or value",type:"value|range",optional:false}]},{name:"ISLOGICAL",category:"information",id:128,description:"Checks whether a value is a logical value (TRUE or FALSE), and returns TRUE or FALSE",example:"=ISLOGICAL(A1:A5)",parameters:[{name:"value",description:"Is the value you want to test. Value can refer to a cell, a formula, or a name that refers to a cell, formula, or value",type:"value|range",optional:false}]},{name:"ERROR.TYPE",category:"information",id:148,description:"Returns a number matching an error value.",example:"=ERROR.TYPE(A1)",parameters:[{name:"errorVal",description:"Is the error value for which you want the identifying number, and can be an actual error value or a reference to a cell containing an error value",type:"value|range",optional:false}]},{name:"ISEVEN",category:"information",id:273,description:"Returns TRUE if the number is even",example:"=ISEVEN(10)",parameters:[{name:"numberParam",description:"Is the value to test",type:"number|range",optional:false}]},{name:"ISODD",category:"information",id:274,description:"Returns TRUE if the number is odd",example:"=ISODD(10)",parameters:[{name:"numberParam",description:"Is the value to test",type:"number|range",optional:false}]},{name:"SHEET",category:"information",id:433,description:"Returns the sheet number of the referenced sheet",example:"=SHEET(A1:A5)",parameters:[{name:"value",description:"Is the name of a sheet or a reference that you want the sheet number of. If omitted the number of the sheet containing the function is returned",type:"value|range",optional:true}]},{name:"SHEETS",category:"information",id:434,description:"Returns the number of sheets in a reference",example:"=SHEETS(A1:A5)",parameters:[{name:"reference",description:"Is a reference for which you want to know the number of sheets it contains. If omitted the number of sheets in the workbook containing the function is returned",type:"range",optional:true}]},{name:"ISFORMULA",category:"information",id:436,description:"Checks whether a reference is to a cell containing a formula, and returns TRUE or FALSE",example:"=ISFORMULA(A1:A5)",parameters:[{name:"reference",description:"Is a reference to the cell you want to test. Reference can be a cell reference, a formula, or name that refers to