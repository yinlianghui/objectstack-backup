rlap"}]}}},{kind:"api",name:"chart axes",summary:"Axis config (type, position, titles, ticks, gridlines, formats, and styling).",notes:["Use chart.xAxis and chart.yAxis to configure the primary axes.","Axis config setters merge; apply small patches without resetting other axis fields."],languages:{javascript:{examples:[{summary:"Axis type + presence",code:["chart.xAxis = { axisType: 'textAxis' };","chart.xAxis = { axisType: 'dateAxis' };","chart.xAxis = { deleted: true, title: 'Years' };","chart.yAxis = { deleted: true, title: 'Revenue' };"].join("\n")},{summary:"Axis titles + text styles (avoid redundant defaults)",code:["chart.xAxis = { title: { text: 'Category', textStyle: { fontSize: 14, bold: true } } };","chart.yAxis = { title: { text: 'Value', textStyle: { fontSize: 12, italic: true, fill: 'accent1' } } };"].join("\n")},{summary:"Axis ordering + crossing",code:["chart.xAxis = { position: 'bottom', orientation: 'maxMin' };","chart.yAxis = { position: 'left', crossBetween: 'between' };","chart.yAxis = { crosses: 'autoZero' };","chart.yAxis = { crossesAt: 2 };","chart.yAxis = { crosses: 'max' };"].join("\n")},{summary:"Tick labels",code:["chart.xAxis = { tickLabelPosition: 'nextTo' };","chart.xAxis = { tickLabelPosition: 'high' };","chart.xAxis = { tickLabelPosition: 'low' };","chart.xAxis = { tickLabelPosition: 'none', tickLabelInterval: 2, tickLabelDistanceFromAxis: 10 };"].join("\n")},{summary:"Tick marks + units",code:["chart.xAxis = { majorUnit: 5, minorUnit: 1 };","chart.xAxis = { majorTickMark: 'outside', minorTickMark: 'inside' };","chart.yAxis = { majorTickMark: 'cross', minorTickMark: 'none' };"].join("\n")},{summary:"Gridlines + axis lines",code:["chart.yAxis = { majorGridlines: { fill: 'background2', style: 'dashed', width: 1 }, minorGridlines: { fill: 'background2', style: 'dotted', width: 0.5 } };","chart.xAxis = { majorGridlines: { fill: 'background2', style: 'solid', width: 1 }, minorGridlines: { fill: 'background2', style: 'dotted', width: 0.5 } };","chart.xAxis = { line: { fill: 'background2', style: 'solid', width: 1 } };","chart.yAxis = { line: { fill: 'background2', style: 'solid', width: 1 } };","","// Hide gridlines:","chart.yAxis = { majorGridlines: null, minorGridlines: null };","chart.xAxis = { majorGridlines: null, minorGridlines: null };"].join("\n")},{summary:"Number formats",code:["chart.xAxis = { numberFormatCode: '0', numberFormatSourceLinked: true };"].join("\n")},{summary:"Axis text style",code:["chart.xAxis = { textStyle: { fontSize: 10 } };","chart.yAxis = { textStyle: { fontSize: 1, fill: 'background1' } };"].join("\n")}]},python:{functionName:"chart.x_axis",examples:[{code:["chart.x_axis = {'axisType': 'textAxis'}","chart.x_axis = {'axisType': 'dateAxis'}","chart.x_axis = {'deleted': True, 'title': 'Years'}","chart.y_axis = {'deleted': True, 'title': 'Revenue'}"].join("\n"),summary:"Axis type + presence"},{code:["chart.x_axis = {'title': {'text': 'Category', 'textStyle': {'fontSize': 14, 'bold': True}}}","chart.y_axis = {'title': {'text': 'Value', 'textStyle': {'fontSize': 12, 'italic': True, 'fill': 'accent1'}}}"].join("\n"),summary:"Axis titles + text styles (avoid redundant defaults)"},{code:["chart.x_axis = {'position': 'bottom', 'orientation': 'maxMin'}","chart.y_axis = {'position': 'left', 'crossBetween': 'between'}","chart.y_axis = {'crosses': 'autoZero'}","chart.y_axis = {'crossesAt': 2}","chart.y_axis = {'crosses': 'max'}"].join("\n"),summary:"Axis ordering + crossing"},{code:["chart.x_axis = {'tickLabelPosition': 'nextTo'}","chart.x_axis = {'tickLabelPosition': 'high'}","chart.x_axis = {'tickLabelPosition': 'low'}","chart.x_axis = {'tickLabelPosition': 'none', 'tickLabelInterval': 2, 'tickLabelDistanceFromAxis': 10}"].join("\n"),summary:"Tick labels"},{code:["chart.x_axis = {'majorUnit': 5, 'minorUnit': 1}","chart.x_axis = {'majorTickMark': 'outside', 'minorTickMark': 'inside'}","chart.y_axis = {'majorTickMark': 'cross', 'minorTickMark': 'none'}"].join("\n"),summary:"Tick marks + units"},{code:["chart.y_axis = {'majorGridlines': {'fill': 'background2', 'style': 'dashed', 'width': 1}, 'minorGridlines': {'fill': 'background2', 'style': 'dotted', 'width': 0.5}}","chart.x_axis = {'majorGridlines': {'fill': 'background2', 'style': 'solid', 'width': 1}, 'minorGridlines': {'fill': 'background2', 'style': 'dotted', 'width': 0.5}}","chart.x_axis = {'line': {'fill': 'background2', 'style': 'solid', 'width': 1}}","chart.y_axis = {'line': {'fill': 'background2', 'style': 'solid', 'width': 1}}","chart.y_axis = {'majorGridlines': None, 'minorGridlines': None}","chart.x_axis = {'majorGridlines': None, 'minorGridlines': None}"].join("\n"),summary:"Gridlines + axis lines"},{code:["chart.x_axis = {'numberFormatCode': '0', 'numberFormatSourceLinked': True}"].join("\n"),summary:"Number formats"},{code:["chart.x_axis = {'textStyle': {'fontSize': 10}}","chart.y_axis = {'textStyle': {'fontSize': 1, 'fill': 'background1'}}"].join("\n"),summary:"Axis text style"}]}}},{kind:"api",name:"categoryAxis",summary:"Alias for the chart category axis. In Granola, this maps to chart.xAxis.",notes:["Prefer chart.xAxis = { ... } for config-style edits.","Also available as chart.axes.categoryAxis."],languages:{javascript:{examples:[{summary:"Show category axis tick labels",code:["chart.xAxis = { deleted: false, tickLabelPosition: 'nextToAxis' };"].join("\n")}]},python:{functionName:"chart.x_axis",examples:[{code:["chart.x_axis = {'deleted': False, 'tickLabelPosition': 'nextToAxis'}"].join("\n"),summary:"Show category axis tick labels"}]}}},{kind:"api",name:"valueAxis",summary:"Alias for the chart value axis. In Granola, this maps to chart.yAxis.",notes:["Prefer chart.yAxis = { ... } for config-style edits.","Also available as chart.axes.valueAxis."],languages:{javascript:{examples:[{summary:"Format value axis gridlines",code:["chart.yAxis = { majorGridlines: { fill: 'background2', style: 'dashed', width: 1 } };"].join("\n")}]},python:{functionName:"chart.y_axis",examples:[{c