ue: true, position: 'dataCallout', fill: { type: 'solid', color: 'background1', pattern: { type: 'percent20', color: 'accent1' } }, stroke: { fill: 'accent1', style: 'solid', width: 1 } };"].join("\n")}]},python:{functionName:"chart.data_labels",examples:[{code:["chart.data_labels = {'showValue': False, 'position': None}","chart.data_labels = {'showValue': True, 'position': 'center', 'textStyle': {'fontSize': 9}}","chart.data_labels = {'showValue': True, 'position': 'inEnd'}","chart.data_labels = {'showValue': True, 'position': 'inBase'}","chart.data_labels = {'showValue': True, 'position': 'outEnd', 'textStyle': {'bold': True, 'fontSize': 10}}"].join("\n"),summary:"Positions + minimal style"},{code:["chart.data_labels = {'showValue': True, 'position': 'dataCallout', 'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'percent20', 'color': 'accent1'}}, 'stroke': {'fill': 'accent1', 'style': 'solid', 'width': 1}}"].join("\n"),summary:"Data callout styling (fill + stroke)"}]}}},{kind:"api",name:"chart dataTable",summary:"Chart data table visibility and styling.",languages:{javascript:{examples:[{summary:"Data table with optional legend keys",code:["chart.dataTable = { visible: true, showLegendKey: true, textStyle: { fontSize: 10 }, fill: { type: 'solid', color: 'background1', pattern: { type: 'smallGrid', color: 'accent3' } } };","chart.dataTable = { visible: true, showLegendKey: false };"].join("\n")}]},python:{functionName:"chart.data_table",examples:[{code:["chart.data_table = {'visible': True, 'showLegendKey': True, 'textStyle': {'fontSize': 10}, 'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'smallGrid', 'color': 'accent3'}}}","chart.data_table = {'visible': True, 'showLegendKey': False}"].join("\n"),summary:"Data table with optional legend keys"}]}}},{kind:"api",name:"chart series",summary:"Series data, styling, number formats, error bars, trendlines, and label overrides.",languages:{javascript:{examples:[{summary:"Series styling via worksheet.charts.add config",code:["const chart = worksheet.charts.add('bar', { categories: ['Q1','Q2'], series: [{ name: '2025', values: [18, 14], line: { fill: '#7c3aed', style: 'solid', width: 2 }, fill: { type: 'solid', color: '#ede9fe', pattern: { type: 'smallCheck', color: '#8b5cf6' } } }, { name: '2026', values: [21, 17], line: { fill: '#d97706', style: 'solid', width: 2 }, fill: { type: 'solid', color: '#fef3c7', pattern: { type: 'dottedDiamond', color: '#f59e0b' } } }] });"].join("\n")},{summary:"Scatter series with xValues (config)",code:["const chart = worksheet.charts.add('scatter', { series: [{ name: 'S1', xValues: [1, 2, 3, 4], values: [2, 4, 3, 5] }] });"].join("\n")},{summary:"Create a series and set categories/values (one-liners)",code:["chart.categories = ['A', 'B', 'C'];","const series = chart.series.add('S1'); series.categories = chart.categories; series.values = [1, 2, 3];"].join("\n")},{summary:"Series value number format code",code:["chart.series.items[0]!.valuesFormatCode = '$0.00';"].join("\n")},{summary:"Error bars",code:["const series = chart.series.items[0]!;","series.errorBars = { type: 'standardError', line: { fill: 'accent1', style: 'solid', width: 1 } };","series.errorBars = { type: 'percentage', value: 5 };","series.errorBars = { type: 'standardDeviation' };"].join("\n")},{summary:"Trendlines",code:["const series = chart.series.items[0]!;","series.trendlines.add('linear', { forecastForward: 2, forecastBackward: 1, intercept: 0, displayEquation: true, displayRSquared: true, stroke: { fill: 'accent1', style: 'dashed', width: 1 } });","series.trendlines.add('polynomial', { polynomialOrder: 3 });","series.trendlines.add('movingAverage', { movingAveragePeriod: 5 });","series.trendlines.add('exponential');","series.trendlines.clear();"].join("\n")},{summary:"Trendline styling (label fill + line alias)",code:["const trend = series.trendlines.add('linear', { line: { fill: 'accent5', style: 'dashed', width: 1 }, label: { fill: { type: 'solid', color: 'background1', pattern: { type: 'smallCheck', color: 'accent6' } } } });"].join("\n")},{summary:"Per-point data label overrides",code:["const series = chart.series.items[1]!;","const label0 = series.dataLabelOverrides.add(0);","label0.showValue = true;","label0.position = 'inEnd';","label0.textStyle.bold = true;","label0.textStyle.fontSize = 10;"].join("\n")},{summary:"Series styling after creation (one-liners)",code:["chart.series.items[0]!.line = { fill: '#3b82f6', style: 'solid', width: 2 };","chart.series.items[0]!.fill = { type: 'solid', color: '#60a5fa' };"].join("\n")},{summary:"Outline-only bars (no fill + visible stroke)",code:["const series = chart.series.items[0]!;","series.fill = { type: 'none' };","series.stroke = { color: 'accent5', style: 'solid', weight: 1.5 };","","// Equivalent format-style surface (useful for agent code):","series.format.fill.clear();","series.format.line = { color: 'accent5', style: 'solid', weight: 1.5 };"].join("\n")}]},python:{functionName:"chart.series",examples:[{code:["chart = worksheet.charts.add('bar', {'categories': ['Q1', 'Q2'], 'series': [{'name': '2025', 'values': [18, 14], 'line': {'fill': '#7c3aed', 'style': 'solid', 'width': 2}, 'fill': {'type': 'solid', 'color': '#ede9fe', 'pattern': {'type': 'smallCheck', 'color': '#8b5cf6'}}}, {'name': '2026', 'values': [21, 17], 'line': {'fill': '#d97706', 'style': 'solid', 'width': 2}, 'fill': {'type': 'solid', 'color': '#fef3c7', 'pattern': {'type': 'dottedDiamond', 'color': '#f59e0b'}}}]})"].join("\n"),summary:"Series styling via worksheet.charts.add config"},{code:["chart = worksheet.charts.add('scatter', {'series': [{'name': 'S1', 'xValues': [1, 2, 3, 4], 'values': [2, 4, 3, 5]}]})"].join("\n"),summary:"Scatter series with xValues (config)"},{code:["chart.categories = ['A', 'B', 'C']","series = chart.series.add('S1')","series.categories = chart.categories","series.values = [1, 2, 3]"].join("\n"),summary:"Create a series and set categories/values (one-liners)"},{code:["chart.series.items[0].values_format_code = '$0.00'"].join("\n"),summary:"Series value number format code"},{code:["series = chart.series.items[0]","series.error_bars = {'type': 'standardError', 'line': {'fill': 'accent1', 'style': 'solid', 'width': 1}}","series.error_bars = {'type': 'percentage', 'value': 5}","series.error_bars = {'type': 'standardDeviation'}"].join("\n"),summary:"Error bars"},{code:["series = chart.series.items[0]","series.trendlines.add('linear', {'forecastForward': 2, 'forecastBackward': 1, 'intercept': 0, 'displayEquation': True, 'displayRSquared': True, 'stroke': {'fill': 'accent1', 'style': 'dashed', 'width': 1}})","series.trendlines.add('polynomial', {'polynomialOrder': 3})","series.trendlines.add('movingAverage', {'movingAveragePeriod': 5})","series.trendlines.add('exponential')","series.trendlines.clear()"].join("\n"),summary:"Trendlines"},{code:["trend = series.trendlines.add('linear', {'line': {'fill': 'accent5', 'style': 'dashed', 'width': 1}, 'label': {'fill': {'type': 'solid', 'color': 'background1', 'pattern': {'type': 'smallCheck', 'color': 'accent6'}}}})"].join("\n"),summary:"Trendline styling (label fill + line alias)"},{code:["series = chart.series.items[1]","label0 = series.data_label_overrides.add(0)","label0.show_value = True","label0.position = 'inEnd'","label0.text_style.bold = True","label0.text_style.font_size = 10"].join("\n"),summary:"Per-point data label overrides"},{code:["chart.series.items[0].line = {'fill': '#3b82f6', 'style': 'solid', 'width': 2}","chart.series.items[0].fill = {'type': 'solid', 'color': '#60a5fa'}"].join("\n"),summary:"Series styling after creation (one-liners)"},{code:["series = chart.series.items[0]","series.fill = {'type': 'none'}","series.stroke = {'color': 'accent5', 'style': 'solid', 'weight': 1.5}","series.format.fill.clear()","series.format.line = {'color': 'accent5', 'style': 'solid', 'weight': 1.5}"].join("\n"),summary:"Outline-only bars (no fill + visible stroke)"}]}}}];var Dyr=[{kind:"api",name:"sparklines",summary:"Sparkline groups for compact trend visuals.",notes:["Use worksheet.sparklines.add({ type, targetRange, sourceData }).","Use worksheet.sparklines.getAll() to list groups.","Use worksheet.sparklines.deleteAll() to remove all groups (safe no-op when empty).","worksheet.sparklines is an alias for worksheet.sparklineGroups."]},{kind:"api",name:"worksheet.sparklines.add",summary:"Create a sparkline group for a target range.",languages:{javascript:{examples:[{code:["sheet.getRange('A1:A6').values = [[1],[2],[3],[2],[4],[6]];","const group = sheet.sparklines.add({","  type: 'line',","  sourceData: sheet.getRange('A1:A6'),","  targetRange: sheet.getRange('B1:B6'),","});","group.displayXAxis = true;"].join("\n"),summary:"Add a line sparkline group"}]},python:{functionName:"worksheet.sparklines.add",examples:[{code:["sheet.get_range('A1:A6').values = [[1], [2], [3], [2], [4], [6]]","group = sheet.sparklines.add({","  'type': 'line',","  'sourceData': sheet.get_range('A1:A6'),","  'targetRange': sheet.get_range('B1:B6'),","})","group.display_x_axis = True"].join("\n"),summary:"Add a line sparkline group"}]}},notes:["targetRange and sourceData accept a Range or an A1 string address.","Use worksheet.sparklines.deleteAll() to clear everything."]}];var Fyr=[{kind:"api",name:"formulas",summary:"Formula authoring and calculation.",tags:["spreadsheet","formulas"],notes:["Write formulas via range.formulas (2D string array).",`range.values accepts strings starting with '=' as formulas; use "'=..." for literal text.`,"Call workbook.recalculate() before reading computed values.","If a newer Excel function appears unsupported in your runtime, replace it with compatible patterns (example: AVERAGEIFS -> SUMIFS/COUNTIFS)."],languages:{javascript:{examples:[{code:['const sheet = workbook.worksheets.add("Sheet1");','const range = sheet.getRange("A1:A2");','range.formulas = [["=1+1"], ["=SUM(2,3)"]];',"workbook.recalculate();","const values = range.values;"].join("\n")}],notes:[]},python:{functionName:"range.formulas",examples:[{code:['sheet = workbook.worksheets.add("Sheet1")','range = sheet.get_range("A1:A2")','range.formulas = [["=1+1"], ["=SUM(2,3)"]]',"workbook.recalculate()","values = range.values"].join("\n")}],notes:[]}}}];var Nyr=[{kind:"api",name:"workbook",summary:"Workbook lifecycle and entry points.",notes:["Create with Workbook.create() or Workbook.load().","Access sheets via workbook.worksheets.","Call workbook.recalculate() before reading formula results.","Export with workbook.render(...) or workbook.toProto()."]},{kind:"api",name:"workbook.render",summary:"Render worksheet previews as PNG/JPEG.",notes:["Use workbook.render({ sheetName, range, format, scale, headers }).","range is A1 notation; center requires width and height.","Provide only one of sheet, sheetName, or sheetIndex.","Use range or center (with width and height)."],languages:{javascript:{examples:[{code:["const png = await workbook.render({","  sheetName: 'Summary',","  range: 'A1:D12',","  format: 'png',","});"].join("\n"),summary:"Render a range preview"}]},python:{functionName:"workbook.render",examples:[{code:["png = workbook.render({","  'sheetName': 'Summary',","  'range': 'A1:D12',","  'format': 'png',","})"].join("\n"),summary:"Render a range preview"}]}}},{kind:"api",name:"workbook.help",summary:"Return NDJSON help about workbook APIs via query and regex search",notes:["Tip: query matches entry names, not example bodies. ","To find an API by keyword, use query='*' to grep across the help index and search=<regex>","Search uses regex matching; for multiple terms use pipes (example: freeze|pane|freeze_panes).","Use `include` param to control payload size.","Formula metadata is exposed under fx.<NAME> entries (ex: fx.LET).","Enums are listed under enum.<Name> (ex: enum.ShapeGeometry)."],examples:[{code:["workbook.help(","  'enum.ShapeGeometry',","  { include: ['index','notes'] },",")"].join("\n"),summary:"Get help for a spe